#!/usr/bin/env bash

# 项目环境变量模板
# 用法：
# 1. 复制本文件为 scripts/load_env.sh
# 2. 按注释填写真实值
# 3. 运行 ./scripts/start.sh

# 服务监听地址
# 一般本机运行保持默认即可。
export AUTOJM_HOST="0.0.0.0"

# 服务监听端口
# QQ 回调和 ngrok/Cloudflare Tunnel 最终都会转发到这个端口。
export AUTOJM_PORT="8080"

# QQ 机器人 AppID
# 获取位置：QQ开放平台 -> 机器人管理后台 -> 开发管理 / 代码开发
export QQ_BOT_APP_ID=""

# QQ 机器人 Secret
# 获取位置：QQ开放平台 -> 机器人管理后台 -> 开发管理 / 代码开发
# 注意：这是敏感信息，不要提交到仓库。
export QQ_BOT_SECRET=""

# 是否使用 QQ 沙箱环境
# 1 表示沙箱，0 表示正式环境。
# 获取依据：如果你当前机器人还在沙箱测试，就填 1。
export QQ_BOT_IS_SANDBOX="1"

# 默认预览长图数量
# 当用户只发“123456”时，默认发送前多少张长图。
export AUTOJM_DEFAULT_PREVIEW_COUNT="5"

# 搜索时最多取多少页进入随机池
# 影响 search / sr 指令的随机范围，数字越大越随机，但请求也越多。
export AUTOJM_TAG_SEARCH_PAGE_LIMIT="3"

# 每次搜索最终随机返回多少条结果
export AUTOJM_TAG_SEARCH_RESULT_COUNT="5"

# 单张图片发送失败时最多重试几次
export AUTOJM_IMAGE_SEND_MAX_RETRIES="3"

# 图片发送失败后的重试间隔，单位秒，逗号分隔
# 例如 1,2,4 表示第 1 次失败后等 1 秒，第 2 次等 2 秒，第 3 次等 4 秒。
export AUTOJM_IMAGE_SEND_RETRY_DELAYS="1,2,4"

# 每张长图发送完成后，额外等待多久再发下一张，单位秒
export AUTOJM_IMAGE_SEND_INTERVAL_SECONDS="0.8"

# 5 合 1 长图的最大宽度
# 数值越小，图片越容易发送成功，但清晰度会略降。
export AUTOJM_LONGIMG_MAX_WIDTH="720"

# 5 合 1 长图的 JPEG 压缩质量，范围通常 1-95
# 数值越小，体积越小。
export AUTOJM_LONGIMG_JPEG_QUALITY="72"

# 是否启用本地缓存 LRU 自动清理
# 1 表示启用，0 表示关闭。
export AUTOJM_AUTO_LRU_CACHE="1"

# 本地下载缓存上限，单位 GB
# 超过后会按最近最少使用策略删除旧资源目录。
export AUTOJM_LOCAL_CACHE_LIMIT_GB="5"

# 本地缓存数据库路径
# 用于记录 LRU 访问时间和清理日志。一般保持默认即可。
export AUTOJM_CACHE_DB_PATH="./.autojm_cache.db"
